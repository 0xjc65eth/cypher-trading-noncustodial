# ── Cypher Trading Non-Custodial ──
# Environment Variables
# Copy this file to .env and fill in your keys

# ==================== WALLET CONNECT ====================
# Get from https://cloud.walletconnect.com
WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ==================== RPC ENDPOINTS ====================
# Get from https://www.alchemy.com or https://infura.io
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ==================== API KEYS ====================
# 1inch API (free tier available)
ONEINCH_API_KEY=your_1inch_api_key

# Jupiter API (Solana) — rate limited free tier
JUPITER_API_URL=https://quote-api.jup.ag/v6

# Uniswap — uses on-chain via ethers.js, no API key needed
# GMX — uses on-chain via ethers.js, no API key needed

# ==================== VOICE (OVOS) ====================
# Whisper model: tiny, base, small, medium, large
WHISPER_MODEL=base
# Wake word: "hey cypher" (custom)
WAKE_WORD=hey_cypher
# TTS engine: mimic3, coqui, elevenlabs
TTS_ENGINE=mimic3

# ==================== BACKEND ====================
BACKEND_PORT=4000
FRONTEND_PORT=3000
VOICE_WEBSOCKET_PORT=8181

# ==================== SECURITY ====================
# ⚠️ NEVER store private keys or seeds here!
# This app is NON-CUSTODIAL — all keys stay on user's device
ENCRYPTION_KEY=change_me_to_random_32_bytes
